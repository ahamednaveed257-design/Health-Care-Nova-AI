CARE_NOVA_LOCAL_REASONING_API_KEY_HEADER=
CARE_NOVA_LOCAL_REASONING_API_AUTH_SCHEME=Bearer
# Copy this file to .env or .env.local before enabling a paid/cloud provider.
# .env.local should be used for local overrides and now wins over .env.
# To switch on every supported model slot at once:
# CARE_NOVA_ENABLE_ALL_MODELS=true
# Minimal OpenAI activation:
# CARE_NOVA_ONLINE_MODE=true
# CARE_NOVA_PAID_MODELS_ENABLED=true
# CARE_NOVA_CLOUD_MODELS_ENABLED=true
# CARE_NOVA_OPENAI_ENABLED=true
# CARE_NOVA_SPECIALIST_LLM_CLOUD_ENABLED=true
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-5.4
CARE_NOVA_OPENAI_ENABLED=false
CARE_NOVA_SPECIALIST_LLM_CLOUD_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=
