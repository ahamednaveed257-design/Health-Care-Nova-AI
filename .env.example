NODE_ENV=production
HOST=0.0.0.0
PORT=4173
CARE_NOVA_PUBLIC_DEPLOYMENT=false
# When true, the server refuses to boot until enterprise config, public-hosting controls, and critical bundled storage files are ready.
CARE_NOVA_STRICT_STARTUP_GUARD=false
ALLOWED_ORIGIN=https://your-domain.example
FRAME_ANCESTORS='self'
ENABLE_HSTS=false
CARE_NOVA_ACCESS_LOG=false
CARE_NOVA_TRUST_PROXY=false
CARE_NOVA_AUDIT_LOG_ENABLED=true
CARE_NOVA_AUDIT_MAX_EVENTS=5000
# Public deployment mode auto-enforces admin auth, patient-scoped access, and mutation protection, but explicit values should still be set before release.
CARE_NOVA_REQUIRE_ADMIN_FOR_MUTATIONS=false
CARE_NOVA_ADMIN_API_TOKEN=
CARE_NOVA_ADMIN_AUTH_REQUIRED=false
CARE_NOVA_ADMIN_HEADER=X-Care-Nova-Admin-Token
CARE_NOVA_ADMIN_SESSION_SECRET=
CARE_NOVA_PATIENT_AUTH_REQUIRED=false
CARE_NOVA_PATIENT_ACCESS_SECRET=
CARE_NOVA_PATIENT_HEADER=X-Care-Nova-Patient-Token
# Optional dedicated signing secret for exportable enterprise release snapshots.
CARE_NOVA_RELEASE_SNAPSHOT_SECRET=
CARE_NOVA_SECRET_PROVIDER=local-env-file
CARE_NOVA_SECRET_ROTATION_DAYS=90
CARE_NOVA_SECRET_LAST_ROTATED_AT=
CARE_NOVA_ADMIN_SESSION_TTL_MINUTES=480
CARE_NOVA_PATIENT_SESSION_TTL_MINUTES=480
CARE_NOVA_ADMIN_COOKIE_NAME=care_nova_admin_session
CARE_NOVA_ADMIN_COOKIE_SECURE=false
CARE_NOVA_MAINTENANCE_MODE=false
CARE_NOVA_READ_ONLY_MODE=false
CARE_NOVA_METRICS_MAX_ERRORS=50
CARE_NOVA_MAX_JSON_BODY_BYTES=5000000
CARE_NOVA_RETENTION_POLICY_OWNER=deployment-owner
CARE_NOVA_RETENTION_REVIEW_FREQUENCY_DAYS=90
CARE_NOVA_RETENTION_MEMORY_DAYS=365
CARE_NOVA_RETENTION_RECORDS_DAYS=2555
CARE_NOVA_RETENTION_GRAPH_DAYS=365
CARE_NOVA_RETENTION_AUDIT_DAYS=365
CARE_NOVA_RETENTION_REVIEW_HISTORY_DAYS=730
CARE_NOVA_RETENTION_TRAINING_DAYS=365
CARE_NOVA_RETENTION_EXTERNAL_CACHE_DAYS=180
CARE_NOVA_RETENTION_MIRROR_DAYS=365
CARE_NOVA_RECOVERY_POLICY_OWNER=deployment-owner
CARE_NOVA_RECOVERY_REVIEW_FREQUENCY_DAYS=90
CARE_NOVA_RECOVERY_TARGET_RPO_HOURS=24
CARE_NOVA_RECOVERY_TARGET_RTO_HOURS=8
CARE_NOVA_RECOVERY_LAST_DRILL_AT=
CARE_NOVA_RECOVERY_LAST_BACKUP_VERIFIED_AT=
CARE_NOVA_RECOVERY_PRIMARY_BACKUP_LOCATION=encrypted-local-backup
CARE_NOVA_RECOVERY_SECONDARY_BACKUP_LOCATION=local-onedrive-mirror
CARE_NOVA_RECOVERY_DRILL_STATUS=review
CARE_NOVA_RECOVERY_AUTOMATION_PLANNED=true
CARE_NOVA_INCIDENT_POLICY_OWNER=deployment-owner
CARE_NOVA_INCIDENT_ESCALATION_CHANNEL=local-ops-bridge
CARE_NOVA_INCIDENT_REVIEW_FREQUENCY_DAYS=90
CARE_NOVA_INCIDENT_TABLETOP_FREQUENCY_DAYS=180
CARE_NOVA_INCIDENT_TARGET_ACK_MINUTES=15
CARE_NOVA_INCIDENT_TARGET_STATUS_UPDATE_MINUTES=60
CARE_NOVA_INCIDENT_LAST_TABLETOP_AT=
CARE_NOVA_INCIDENT_LAST_RUNBOOK_REVIEW_AT=
CARE_NOVA_INCIDENT_SEV1_RUNBOOK_READY=true
CARE_NOVA_INCIDENT_SEV2_RUNBOOK_READY=true
CARE_NOVA_INCIDENT_SEV3_RUNBOOK_READY=true
CARE_NOVA_INCIDENT_COMMS_TEMPLATE_READY=true
CARE_NOVA_INCIDENT_ONCALL_MODE=local-owner
CARE_NOVA_INCIDENT_AUTOMATION_PLANNED=true
CARE_NOVA_AI_MODE=offline-first
CARE_NOVA_MODEL_ROUTING_POLICY=local-first-auto
CARE_NOVA_MODEL_COST_POLICY=lowest-cost
CARE_NOVA_CLOUD_COMPLEXITY_THRESHOLD=72
CARE_NOVA_FORCE_OFFLINE=false
CARE_NOVA_OFFLINE_ONLY=false
CARE_NOVA_INTERNET_AVAILABLE=true
CARE_NOVA_ENABLE_ALL_MODELS=false
CARE_NOVA_PAID_MODELS_ENABLED=false
CARE_NOVA_CLOUD_MODELS_ENABLED=false
CARE_NOVA_LOCAL_MODELS=deepseek-r1,llama-3,mistral,gemma,qwen
CARE_NOVA_AUTO_DETECT_LOCAL_RUNTIME=true
LOCAL_LLM_ENABLED=true
LOCAL_LLM_PROVIDER=auto
LOCAL_LLM_URL=
