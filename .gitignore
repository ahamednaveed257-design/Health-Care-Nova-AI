# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment and secrets
.env
.env.*
!.env.example

# Logs and runtime output
*.log
*.out.log
*.err.log
care-nova-server*.log
server*.log

# Local patient/runtime data
data/memory/*
data/records/*
data/graph/*
data/training/*
data/external/*
data/audit/*
data/onedrive-mirror/*
!data/memory/.gitkeep
!data/records/.gitkeep
!data/graph/.gitkeep
!data/training/.gitkeep
!data/external/.gitkeep
!data/audit/.gitkeep
!data/onedrive-mirror/.gitkeep
!data/README.md

# Keep the curated offline seed database in Git
!data/
!data/offline-medical-db.json

# Large optional guide videos and generated video output
public/media/*.webm
!public/media/care-nova-guide-poster.svg
videos/**/renders/
videos/**/tools/
videos/**/.media/

# Screenshots and generated QA artifacts
github-pages-dist/
github-public-package/
screenshots/
*.trace.zip
playwright-report/
test-results/
coverage/

